name: Validate Pack

on:
  push:
    branches: [main]
    paths:
      - 'pack/**'
      - 'empack.yml'
      - 'templates/**'
      - '.github/workflows/validate.yml'
  pull_request:
    paths:
      - 'pack/**'
      - 'empack.yml'
      - 'templates/**'
  workflow_dispatch:

jobs:
  validate:
    name: Validate Modpack
    runs-on: ubuntu-latest
    timeout-minutes: 10

    steps:
      - uses: actions/checkout@v6

      - uses: actions/setup-go@v5
        with:
          go-version: 'stable'

      - name: Install packwiz
        run: go install github.com/packwiz/packwiz@latest

      - name: Verify pack is up to date
        run: |
          cd pack
          packwiz refresh
          if ! git diff --exit-code; then
            echo "::error::Pack index is stale. Run 'packwiz refresh' locally and commit."
            exit 1
          fi

      - name: Build mrpack
        run: |
          cd pack
          packwiz mr export
